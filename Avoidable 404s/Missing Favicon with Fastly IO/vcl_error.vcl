# Intercept the custom error code triggered in vcl_fetch when the origin 404s on the fallback favicon.
# This serves a placeholder image via synthetic content to the client instead of hitting them with a full HTML 404 page,
# thereby saving bandwidth, satisfying the browser silently, and preventing error loops.
if (obj.status == 604 && obj.response == "Missing Favicon") {
  set obj.status = 200;
  set obj.response = "OK";
  
  # Map the correct MIME type based on the initial request
  if (req.http.X-Orig-Icon-Ext == "ico") {
    set obj.http.Content-Type = "image/x-icon";
  } elsif (req.http.X-Orig-Icon-Ext == "svg") {
    set obj.http.Content-Type = "image/svg+xml";
  } else {
    set obj.http.Content-Type = "image/png";
  }

  # Cache the placeholder synthetic response rigidly for 7 days
  set obj.http.Cache-Control = "max-age=604800, public";
  
  # Serve a very simple red "X" image in bitmap format
  synthetic.base64 {"
Qk2KBAAAAAAAAIoAAAB8AAAAEAAAABAAAAABACAAAwAAAAAEAAAAAAAAAAAAAAAAAAAAAAAAAAD/AAD/AAD/
AAAAAAAA/0JHUnOPwvUoUbgeFR6F6wEzMzMTZmZmJmZmZgaZmZkJPQrXAyhcjzIAAAAAAAAAAAAAAAAEAAAA
AAAAAAAAAAAAAAAA////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////wAA///p6f//////////////////////////////////////
///////p6f//AAD////////////////////////p6f//AAD//+np////////////////////////////////
///p6f//AAD//+np/////////////////////////////+np//8AAP//6en////////////////////////p
6f//AAD//+np////////////////////////////////////////6en//wAA///p6f/////////////p6f//
AAD//+np///////////////////////////////////////////////////p6f//AAD//+np///p6f//AAD/
/+np/////////////////////////////////////////////////////////////+np//8AAP//AAD//+np
///////////////////////////////////////////////////////////////////p6f//AAD//wAA///p
6f/////////////////////////////////////////////////////////////p6f//AAD//+np///p6f//
AAD//+np///////////////////////////////////////////////////p6f//AAD//+np////////////
/+np//8AAP//6en////////////////////////////////////////p6f//AAD//+np////////////////
////////6en//wAA///p6f/////////////////////////////p6f//AAD//+np////////////////////
///////////////p6f//AAD//+np////////////////////////AAD//+np////////////////////////
/////////////////////+np//8AAP//////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////
  "};
  return (deliver);
}

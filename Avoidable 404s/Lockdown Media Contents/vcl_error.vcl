/////////////////////////////////////////AAD/AAD/AAD/////AAD/AAD/AAD////////////
////////////////////////////////////////////////////////////////////////////////
/////////////AAD/AAD/AAD/AAD/AAD////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////AAD/AAD/
  "};
  return (deliver);
}

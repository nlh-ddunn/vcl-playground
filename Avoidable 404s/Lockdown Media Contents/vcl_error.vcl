# Intercept the custom 605 error from vcl_fetch and serve a synthetic placeholder image.
# This serves a 32x32 red "X" to prevent loading large 404 HTML pages for broken images.
if (obj.status == 605 && obj.response == "Missing Media Image") {
  set obj.status = 200;
  set obj.response = "OK";
  
  # Map the correct MIME type
  set obj.http.Content-Type = "image/png";

  # Cache the placeholder image for exactly 1 hour, preventing cache overflow.
  set obj.http.Cache-Control = "max-age=3600, public";
  
  # Serve a 32x32 red "X" image in bitmap format
  synthetic.base64 {"
Qk02DAAAAAAAADYAAAAoAAAAIAAAACAAAAABABgAAAAAAAAMAAAAAAAAAAAAAAAAAAAAAAAAAAD/AAD/
////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////AAD/AAD/AAD/AAD/AAD////////////////////////////
////////////////////////////////////////////////////////////////////////////////
/////////////AAD/AAD/AAD/////AAD/AAD/AAD////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////AAD/AAD
/AAD/////////////AAD/AAD/AAD////////////////////////////////////////////////////
/////////////////////////////////////////////////////AAD/AAD/AAD////////////////
/////AAD/AAD/AAD////////////////////////////////////////////////////////////////
/////////////////////////////////AAD/AAD/AAD/////////////////////////////AAD/AAD
/AAD/////////////////////////////////////////////////////////////////////////AAD
/AAD/AAD/////////////////////////////////////AAD/AAD/AAD////////////////////////
/////////////////////////////////////////AAD/AAD/AAD////////////////////////////
/////////////AAD/AAD/AAD////////////////////////////////////////////////////////
/////AAD/AAD/AAD/////////////////////////////////////////////////////AAD/AAD/AAD
/////////////////////////////////////////////////AAD/AAD/AAD////////////////////
/////////////////////////////////////////AAD/AAD/AAD////////////////////////////
/////////////AAD/AAD/AAD////////////////////////////////////////////////////////
/////////////AAD/AAD/AAD/////////////////////////////////AAD/AAD/AAD////////////
/////////////////////////////////////////////////////////////////AAD/AAD/AAD////
/////////////////////AAD/AAD/AAD////////////////////////////////////////////////
/////////////////////////////////////AAD/AAD/AAD/////////////////AAD/AAD/AAD////
////////////////////////////////////////////////////////////////////////////////
/////////AAD/AAD/AAD/////////AAD/AAD/AAD////////////////////////////////////////
/////////////////////////////////////////////////////////////AAD/AAD/AAD/AAD/AAD
/AAD////////////////////////////////////////////////////////////////////////////
/////////////////////////////////AAD/AAD/AAD/AAD////////////////////////////////
////////////////////////////////////////////////////////////////////////////////
/AAD/AAD/AAD/AAD////////////////////////////////////////////////////////////////
/////////////////////////////////////////////AAD/AAD/AAD/AAD/AAD/AAD////////////
////////////////////////////////////////////////////////////////////////////////
/////////AAD/AAD/AAD/////////AAD/AAD/AAD////////////////////////////////////////
/////////////////////////////////////////////////////AAD/AAD/AAD////////////////
/AAD/AAD/AAD////////////////////////////////////////////////////////////////////
/////////////////AAD/AAD/AAD/////////////////////////AAD/AAD/AAD////////////////
/////////////////////////////////////////////////////////////AAD/AAD/AAD////////
/////////////////////////AAD/AAD/AAD////////////////////////////////////////////
/////////////////////////AAD/AAD/AAD/////////////////////////////////////////AAD
/AAD/AAD/////////////////////////////////////////////////////////////AAD/AAD/AAD
/////////////////////////////////////////////////AAD/AAD/AAD////////////////////
/////////////////////////////////AAD/AAD/AAD////////////////////////////////////
/////////////////////AAD/AAD/AAD/////////////////////////////////////////////AAD
/AAD/AAD/////////////////////////////////////////////////////////////////AAD/AAD
/AAD/////////////////////////////////////AAD/AAD/AAD////////////////////////////
/////////////////////////////////////////////AAD/AAD/AAD////////////////////////
/////AAD/AAD/AAD////////////////////////////////////////////////////////////////
/////////////////AAD/AAD/AAD/////////////////////AAD/AAD/AAD////////////////////
/////////////////////////////////////////////////////////////////////AAD/AAD/AAD
